rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if request.auth != null;

      // Clients may only manage membership metadata.
      allow create, update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'updatedAt', 'createdBy', 'createdAt', 'roomId']);
    }

    // Gameplay-critical state should be written only by trusted backend logic.
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
