{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blossom2 Power DSL",
  "type": "object",
  "required": ["trigger", "effects"],
  "properties": {
    "trigger": { "enum": ["onPlay", "onActivate"] },
    "action": { "enum": ["root", "toTheSun", "pollinate"] },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "enum": [
              "gainResource",
              "spendResource",
              "gainSunlight",
              "spendSunlight",
              "drawCards",
              "tuckCards",
              "discardCards",
              "if",
              "choice"
            ]
          },
          "resource": { "enum": ["water", "compost", "pollinator", "mineral", "trellis"] },
          "amount": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
